//- views/index.pug
extends layout

block pageTitle
  | Willkommen bei Kafi AG

block headerLeft
  label Guthaben:
  span#pay-inserted= `${(status.payment.inserted||0).toFixed(2)} ${status.currency}`

block headerRight
  if status.lowStock && status.lowStock.length || status.descaleWarning
    button.btn.small.warn-icon(
      type="button"
      onclick="openWarningModal()"
      title="Warnungen anzeigen"
    ) ⚠️

  a.btn.small(href="/superuser") SuperUser

block content

  // KACHELN
  main.main.full
    .drinks
      each d in drinks
        if d.active
          a.card.drink(
            href=`/pay/${d.id}`
            class=(!d.available ? 'disabled' : '')
            data-id=d.id
          )
            .title #{d.name}
            .price
              | #{d.price.toFixed(2)} #{status.currency}
              if d.maxPriceMod > 0 && d.recipe.coffee > 0
                br
                span(style="font-size:.85rem; opacity:.75")
                  | + #{d.maxPriceMod.toFixed(2)} #{status.currency}
            if !d.available
              .note Zutat leer


  // WARN-MODAL
  #warning-modal.modal.hidden
    .modal-backdrop(onclick="closeWarningModal()")
    .modal-content
      h2 ⚠️ Maschinenwarnung

      if status && status.lowStock && status.lowStock.length
        h3 ❌ Mindestbestand unterschritten
        .warn-grid
          each item in status.lowStock
            - const key = (item.key || item.name || '').toLowerCase();
            - let icon = '⚠️';
            - if (key.includes('coffee')) icon = '☕';
            - else if (key.includes('milk')) icon = '🥛';
            - else if (key.includes('chocolate')) icon = '🍫';

            .warn-item
              .warn-icon #{icon}
              .warn-label #{item.name}

      if status && status.descaleWarning
        h3 🧼 Entkalkung
        .warn-item.single
          .warn-icon 🧼
          .warn-label
            | Entkalkung in #{status.descaleIn} Zubereitungen

      .modal-actions
        button.btn.small(onclick="closeWarningModal()") Schliessen